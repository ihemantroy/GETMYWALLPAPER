# ── Supabase ─────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Project Settings → API → service_role. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated admin emails granted access to /admin
ADMIN_EMAILS=you@example.com

# ── Google AdSense (optional; ads render only when set) ──────────────
NEXT_PUBLIC_ADSENSE_CLIENT=

# Optional: enables admin "Import from Pexels" (get a free key at pexels.com/api)
PEXELS_API_KEY=
# Optional: enables admin "Import from Unsplash" (get a free key at unsplash.com/developers)
UNSPLASH_ACCESS_KEY=

# Daily push notifications (web-push). Public key lives in src/lib/constants.ts.
# Add these in Vercel to enable sending:
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ihemantroy@gmail.com
CRON_SECRET=
